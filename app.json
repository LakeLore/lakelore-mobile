{
  "expo": {
    "name": "LakeLore",
    "slug": "lakelore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "lakelore",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4efe4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lakeloreapp.lakelore",
      "infoPlist": {}
    },
    "android": {
      "package": "com.lakeloreapp.lakelore",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4efe4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "privacyPolicyUrl": "https://lakeloreapp.com/privacy"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
